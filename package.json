{
  "name": "docs-v2",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "bun --bun astro build && npx pagefind --site dist",
    "preview": "astro preview",
    "astro": "astro",
    "check": "bun run --parallel check:format check:lint check:type",
    "check:format": "bun run --parallel check:oxfmt check:astro",
    "check:oxfmt": "bunx oxfmt --check .",
    "check:astro": "bunx prettier --check '**/*.astro'",
    "check:lint": "bunx oxlint",
    "check:type": "bun --bun astro check",
    "fix": "bun run --sequential fix:format fix:lint",
    "fix:format": "bun run --sequential fix:oxfmt fix:astro",
    "fix:oxfmt": "bunx oxfmt .",
    "fix:astro": "bunx prettier --write '**/*.astro'",
    "fix:lint": "bunx oxlint --fix",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/react": "^5.0.2",
    "@astrojs/sitemap": "^3.7.2",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@pagefind/default-ui": "^1.4.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "astro": "^6.1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@botpress/api": "^1.86.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.4",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.19.0",
    "typescript": "^6.0.2"
  }
}
