---
import Icon from "@/components/Icon.astro";

interface Props {
  name: string;
  comment?: string;
  class?: string;
}

const { name, comment, class: className } = Astro.props;
---

<div class:list={["flex items-center gap-2 py-1", className]}>
  <Icon icon="file" class="text-stone-500 dark:text-stone-400" />
  <span>{name}</span>
  {
    comment && (
      <span class="text-stone-500 dark:text-stone-400"># {comment}</span>
    )
  }
</div>
