---
interface Props {
  cols?: number;
  class?: string;
}

const { cols = 2, class: className } = Astro.props;

const colClasses: Record<number, string> = {
  1: "sm:grid-cols-1",
  2: "sm:grid-cols-2",
  3: "sm:grid-cols-3",
  4: "sm:grid-cols-4",
};

const gridClass = colClasses[cols] || colClasses[2];
---

<div
  class={`prose dark:prose-invert grid gap-4 ${gridClass} ${className || ""}`}
>
  <slot />
</div>
