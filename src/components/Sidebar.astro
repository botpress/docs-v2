---
import type { SidebarNode } from '../lib/sidebar-types'
import SidebarTreeView from './SidebarTreeView.tsx'
import ThemeToggle from './ThemeToggle.tsx'

interface NavItem {
  label: string
  href: string
  icon: 'home'
}

interface Props {
  currentPath: string
  navItems: NavItem[]
  tree: SidebarNode[]
  siteName?: string | null
  siteLogo?: string | null
  siteLogoDark?: string | null
}

const { currentPath, navItems, tree, siteName, siteLogo, siteLogoDark } = Astro.props
const hasLogo = !!(siteLogo || siteLogoDark)

function isActive(href: string): boolean {
  const norm = currentPath.endsWith('/') ? currentPath.slice(0, -1) : currentPath
  const normHref = href.endsWith('/') ? href.slice(0, -1) : href
  if (normHref === '' || normHref === '/') return norm === '' || norm === '/'
  return norm === normHref
}
---

<aside class="flex h-full w-[268px] shrink-0 flex-col bg-stone-100 dark:bg-stone-950">
  <div class="flex h-13 items-center pl-[1.75rem] pr-4">
    <img
      src={siteLogo ?? siteLogoDark ?? undefined}
      alt={siteName || 'Docs'}
      class={`h-7 w-auto shrink-0 object-contain${siteLogoDark ? ' dark:hidden' : ''}`}
      style={hasLogo ? undefined : { display: 'none' }}
    />
    <img
      src={siteLogoDark ?? undefined}
      alt={siteName || 'Docs'}
      class={`h-7 w-auto shrink-0 object-contain${siteLogoDark ? ' hidden dark:block' : ' hidden'}`}
    />
    <span
      class="text-sm font-semibold text-stone-900 dark:text-stone-100"
      style={hasLogo ? { display: 'none' } : undefined}
    >{siteName || 'Docs'}</span>
  </div>

  <div class="px-3">
    <button
      type="button"
      class="relative flex h-9 w-full cursor-pointer items-center rounded-full border border-stone-200 bg-white pl-9 pr-3 text-sm text-stone-500 shadow-none transition-[color,box-shadow] hover:border-stone-300 dark:border-stone-800 dark:bg-white/5 dark:text-stone-400 dark:hover:border-stone-700"
      data-hc-search-trigger
    >
      <svg class="absolute top-1/2 left-3 size-4 -translate-y-1/2 text-stone-500 dark:text-stone-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8" />
        <path d="m21 21-4.3-4.3" />
      </svg>
      Search...
      <kbd class="pointer-events-none ml-auto inline-flex h-5 min-w-5 items-center justify-center gap-0.5 rounded px-1 font-sans text-[11px] font-medium text-stone-400 select-none bg-stone-100 border border-stone-200 dark:bg-stone-800 dark:border-stone-700 dark:text-stone-500">
        <span class="text-xs">⌘</span>K
      </kbd>
    </button>
  </div>

  <script>
    document.querySelector('[data-hc-search-trigger]')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('hc:open-search'))
    })
  </script>

  <nav class="px-3">
    <ul class="space-y-0.5">
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[
                'flex items-center gap-2 rounded-md pl-4 pr-2 py-1.5 text-sm transition-colors',
                isActive(item.href)
                  ? 'hc-nav-active font-medium'
                  : 'text-stone-600 hover:bg-black/5 dark:text-stone-400 dark:hover:bg-white/5',
              ]}
            >
              {item.label === 'Home' && (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
                  <path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                </svg>
              )}
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="relative flex-1 overflow-hidden">
    <div class="pointer-events-none absolute top-0 left-0 z-10 h-8 w-[calc(100%-8px)] bg-gradient-to-b from-stone-100 from-30% to-transparent dark:from-stone-950"></div>
    <div class="h-full overflow-y-auto px-3 pt-6 pb-4" style="scrollbar-gutter: stable">
      <SidebarTreeView client:load nodes={tree} currentPath={currentPath} />
    </div>
  </div>

  <div class="border-t border-stone-200 px-4 py-3 dark:border-stone-800">
    <ThemeToggle client:load />
  </div>
</aside>
