---
import SearchButton from "./SearchButton.tsx";
import Card from "./Card.astro";
import LinkCard from "./LinkCard.astro";
import Footer from "./footer.astro";

interface CardData {
  title: string;
  img: string;
  cta: string;
  href: string;
  description: string;
  badge?: string;
}

const cards: CardData[] = [
  {
    title: "ADK",
    img: "/homepage-assets/adk.jpg",
    cta: "Install the CLI",
    href: "/adk/introduction",
    description: "TypeScript library for building AI agents from code",
    badge: "Beta",
  },
  {
    title: "Studio",
    img: "/homepage-assets/studio.jpg",
    cta: "Build an agent",
    href: "/studio/introduction",
    description: "Visual, drag-and-drop interface for building AI agents",
  },
  {
    title: "Desk",
    img: "/homepage-assets/desk.jpg",
    cta: "Import your customers",
    href: "/desk/introduction",
    description: "Customer support workspace for human-AI teams",
  },
];
---

<div class="w-full overflow-y-auto">
  <div
    class="mx-auto flex max-w-[68rem] flex-col flex-wrap gap-8 px-8 md:flex-row lg:px-16 mb-8 lg:mb-0"
  >
    <div class="relative z-10 max-w-3xl pt-8 lg:pt-16 lg:pb-12">
      <h1
        class="block font-heading text-3xl font-medium tracking-tight text-stone-900 md:text-4xl dark:text-stone-50"
      >
        Documentation
      </h1>
      <div
        class="mx-auto mt-4 mb-8 text-md text-stone-500 md:text-lg dark:text-stone-400"
      >
        Learn how to use Botpress, the complete AI agent platform.
      </div>
      <div class="flex gap-4">
        <SearchButton client:load />
        <a
          href="https://discord.gg/botpress"
          target="_blank"
          rel="noreferrer"
          class="rounded-lg border border-stone-600 bg-white px-4 py-2 text-center text-[0.9rem] leading-[130%] transition-all dark:bg-stone-950"
        >
          Get help
        </a>
      </div>
    </div>
  </div>

  <div
    class="mx-auto flex max-w-[68rem] flex-col flex-wrap px-8 pb-4 md:flex-row md:gap-8 lg:px-16"
  >
    {
      cards.map((card) => (
        <div class="md:max-w-[33.333%] md:flex-[1_1_0%]">
          <Card
            title={card.title}
            img={card.img}
            cta={card.cta}
            href={card.href}
          >
            {card.description}
            {card.badge && (
              <span class="ml-2 inline-flex items-center rounded-full border border-stone-200 bg-stone-100 px-2 py-0.5 text-xs font-medium text-stone-600 dark:border-stone-700 dark:bg-stone-800 dark:text-stone-400">
                {card.badge}
              </span>
            )}
          </Card>
        </div>
      ))
    }
  </div>

  <div
    class="mx-auto mt-4 flex max-w-[68rem] flex-col flex-wrap px-8 md:flex-row md:gap-8 lg:px-16"
  >
    <div class="md:max-w-[50%] md:flex-[1_1_0%]">
      <LinkCard
        href="/webchat/get-started/introduction"
        title="Webchat"
        description="Custom frontend for your AI agent."
        icon="message-square"
      />
    </div>
    <div class="md:max-w-[50%] md:flex-[1_1_0%]">
      <LinkCard
        href="/integrations/introduction"
        title="Integrations"
        description="Channels to deploy or interact with your agent."
        icon="plug"
      />
    </div>
  </div>

  <div class="mx-auto max-w-[68rem] px-8 lg:px-16">
    <Footer />
  </div>
</div>
