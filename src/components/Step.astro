---
import { Icon } from "astro-icon/components";
import { slugify } from "@/lib/icon-utils";

interface Props {
  title?: string;
  class?: string;
}

const { title, class: className } = Astro.props;
const stepId = title ? slugify(title) : undefined;
---

<div
  id={stepId}
  class:list={[
    "group/step relative flex items-start pb-5 [counter-increment:step] scroll-mt-20",
    className,
  ]}
>
  <div
    class="absolute top-11 h-[calc(100%-2.75rem)] w-px bg-stone-200/70 last:bg-gradient-to-b last:from-stone-200 last:via-stone-200 last:via-80% last:to-transparent dark:bg-white/10 dark:last:from-white/10 dark:last:via-white/10"
  >
  </div>
  <a
    href={stepId ? `#${stepId}` : undefined}
    class="group/stepnum absolute ml-[-13px] py-2 step-anchor no-underline"
    aria-label={title ? `Step: ${title}` : undefined}
    tabindex="-1"
  >
    <div
      class="relative flex size-7 shrink-0 items-center justify-center rounded-full bg-stone-50 font-semibold text-stone-900 dark:bg-white/10 dark:text-stone-50"
    >
      <span
        class:list={[
          "text-xs leading-none before:content-[counter(step)] transition-opacity duration-100",
          stepId && "group-hover/stepnum:opacity-0",
        ]}
      ></span>
      {stepId && (
        <span
          class="absolute inset-0 flex items-center justify-center opacity-0 group-hover/stepnum:opacity-100 transition-opacity duration-100 text-stone-500 dark:text-stone-400"
        >
          <Icon name="lucide:link" class="size-3" />
        </span>
      )}
    </div>
  </a>
  <div class="w-full overflow-hidden pr-px pl-8">
    {
      title && (
        <p class="mt-2 font-heading text-xl font-semibold text-stone-900 dark:text-stone-200">
          {title}
        </p>
      )
    }
    <div class:list={["prose dark:prose-invert", { "mt-2": !title }]}>
      <slot />
    </div>
  </div>
</div>
