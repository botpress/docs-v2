---
import { ArrowUpRight, ChevronRight } from "lucide-react";
import Icon from "./Icon.astro";

interface Props {
  title?: string;
  icon?: string;
  img?: string;
  href?: string;
  cta?: string;
  horizontal?: boolean;
  external?: boolean;
  class?: string;
}

const {
  title,
  icon,
  img,
  href,
  cta,
  horizontal,
  external,
  class: className,
} = Astro.props;

const isExternal = external || href?.startsWith("http");
const Component = href ? "a" : "div";
const linkProps = isExternal ? { target: "_blank", rel: "noreferrer" } : {};
---

<Component
  href={href}
  {...linkProps}
  class:list={[
    "not-prose group relative my-2 block w-full overflow-hidden rounded-xl border border-stone-950/10 bg-white font-normal no-underline ring-2 ring-transparent dark:border-white/10 dark:bg-stone-900",
    href && "cursor-pointer hover:border-primary",
    href &&
      "focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary",
    className,
  ]}
>
  {
    img && (
      <img
        alt={title ?? ""}
        src={img}
        class="not-prose w-full object-cover object-center"
      />
    )
  }
  <div
    class:list={[
      "relative px-6 py-5",
      horizontal && "flex items-center gap-x-4",
    ]}
  >
    {
      href && isExternal && (
        <div
          aria-hidden="true"
          class="absolute top-5 right-5 text-stone-400 group-hover:text-primary dark:text-stone-500"
        >
          <ArrowUpRight className="size-4" />
        </div>
      )
    }

    {
      icon && (
        <div class="size-6 fill-stone-800 text-stone-800 dark:fill-stone-100 dark:text-stone-100">
          <Icon icon={icon} size={20} class="size-5" />
        </div>
      )
    }

    <div class="min-w-0 flex-1">
      {
        title && (
          <h2
            class:list={[
              "not-prose text-base font-semibold text-stone-800 dark:text-white",
              icon && !horizontal && "mt-4",
            ]}
          >
            {title}
          </h2>
        )
      }
      <div
        class:list={[
          "mt-1 text-sm font-normal leading-6",
          title
            ? "text-stone-600 dark:text-stone-400"
            : "text-stone-700 dark:text-stone-300",
          horizontal && "mt-0",
        ]}
      >
        <slot />
      </div>
      {
        cta && (
          <div class="mt-8">
            <span class="flex items-center gap-2 text-left text-sm font-medium text-stone-600 group-hover:text-primary dark:text-stone-400">
              {cta}
              <ChevronRight className="size-4" />
            </span>
          </div>
        )
      }
    </div>
  </div>
</Component>
