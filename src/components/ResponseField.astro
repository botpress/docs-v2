---
interface Props {
  name?: string;
  type?: string;
  required?: boolean;
  deprecated?: boolean;
}
const { name = "", type, required = false, deprecated = false } = Astro.props;
---

<div class="not-prose border-b border-stone-100 py-6 last:border-b-0 dark:border-stone-800/50">
  <div class="flex flex-wrap items-center gap-2">
    {name && (
      <span class="font-mono text-sm font-semibold">
        <span class="text-primary">{name}</span>
      </span>
    )}
    {type && (
      <span class="inline-flex items-center rounded-md border border-transparent bg-stone-100/50 px-2 py-1 text-xs font-medium leading-relaxed text-stone-600 dark:bg-white/5 dark:text-stone-200">
        <span class="font-mono font-semibold">{type}</span>
      </span>
    )}
    {required && (
      <span class="inline-flex h-5 items-center rounded-md border border-transparent bg-red-100/50 px-2 py-0.5 text-xs font-medium text-red-600 dark:bg-red-400/10 dark:text-red-300">required</span>
    )}
    {deprecated && (
      <span class="inline-flex h-5 items-center rounded-md border border-transparent bg-amber-100/50 px-2 py-0.5 text-xs font-medium text-amber-600 dark:bg-amber-400/10 dark:text-amber-300">deprecated</span>
    )}
  </div>
  {Astro.slots.has('default') && (
    <div class="expandable-content mt-4 text-sm text-stone-600 dark:text-stone-400 [&>p:first-child]:mt-0 [&>p:last-child]:mb-0">
      <slot />
    </div>
  )}
</div>
