---
import { getEntry } from "astro:content";
import { IntegrationCards as IntegrationCardsReact } from "./IntegrationCards";

interface Props {
  integration: string;
}

const { integration } = Astro.props;
const entry = await getEntry("integrations", integration);
const actions = (entry?.data.actions ?? {}) as Record<
  string,
  Record<string, unknown>
>;
---

{
  Object.keys(actions).length > 0 && (
    <IntegrationCardsReact actions={actions} client:load />
  )
}
