---
import { getEntry } from "astro:content";
import { IntegrationEvents as IntegrationEventsReact } from "./IntegrationEvents";

interface Props {
  integration?: string;
}

const { integration } = Astro.props;
const slug = Astro.params.slug as string | undefined;
const integrationSlug =
  integration ?? slug?.split("integration-guides/")[1]?.split("/")[0];
const entry = integrationSlug
  ? await getEntry("integrations", integrationSlug)
  : undefined;
const events = (entry?.data.events ?? {}) as Record<
  string,
  Record<string, unknown>
>;
---

{
  Object.keys(events).length > 0 && (
    <IntegrationEventsReact events={events} client:load />
  )
}
