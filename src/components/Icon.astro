---
import { Icon as AstroIcon } from "astro-icon/components";
import clsx from "clsx";
import type { IconName } from "@/types/icons";

interface Props {
  icon: IconName;
  class?: string;
}

const { icon, class: className } = Astro.props;

// Unknown icon names are caught at compile time: IconName is derived from
// @iconify-json/lucide/icons.json, so TypeScript will reject any invalid name.
// astro-icon renders nothing silently at runtime, but that path is unreachable
// with a valid build.
const resolved = icon.includes(":") ? icon : `lucide:${icon}`;
---

<AstroIcon name={resolved} class={clsx(className, "size-4", "icon")} />

<style>
  :global(:is(p, li, strong, em, a)) .icon {
    display: inline;
    vertical-align: middle;
  }
</style>
