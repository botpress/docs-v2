---
interface Props {
  icon: string;
  size?: number;
  color?: string;
  class?: string;
}

const { icon, size = 16, color, class: className } = Astro.props;
const url = `https://d3gk2c5xim1je2.cloudfront.net/lucide/v0.545.0/${icon.toLowerCase()}.svg`;

const style = {
  width: `${size}px`,
  height: `${size}px`,
  display: "inline-block",
  verticalAlign: "middle",
  WebkitMaskImage: `url(${url})`,
  WebkitMaskRepeat: "no-repeat",
  WebkitMaskPosition: "center",
  WebkitMaskSize: "100%",
  maskImage: `url(${url})`,
  maskRepeat: "no-repeat",
  maskPosition: "center",
  maskSize: "100%",
  backgroundColor: color || "currentColor",
};
---

<svg class={`inline ${className || ""}`} style={style}></svg>
