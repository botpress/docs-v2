---
import { Icon as AstroIcon } from "astro-icon/components";
import clsx from "clsx";
import type { IconName } from "@/types/icons";

interface Props {
  icon: IconName;
  class?: string;
}

const { icon, class: className } = Astro.props;

const resolved = icon.includes(":") ? icon : `lucide:${icon}`;
---

<AstroIcon name={resolved} class={clsx(className, "size-4", "icon")} />

<style>
  :global(:is(p, li, strong, em, a)) .icon {
    display: inline;
    vertical-align: middle;
  }
</style>
