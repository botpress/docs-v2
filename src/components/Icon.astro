---
import { icons } from "lucide-react";
import clsx from "clsx";

interface Props {
  icon: keyof typeof icons;
  class?: string;
}

const { icon, class: className } = Astro.props;
const IconComponent = icons[icon];

if (!IconComponent) {
  throw new Error(`Icon "${icon}" not found in lucide-react`);
}
---

<IconComponent className={clsx(className, "size-4", "icon")} />

<style>
  :global(p) .icon {
    display: inline;
  }
</style>
