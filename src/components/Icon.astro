---
import { Icon as AstroIcon } from "astro-icon/components";
import clsx from "clsx";
import { toLucideKebab } from "@/lib/icon-utils";

interface Props {
  icon: string;
  class?: string;
}

const { icon, class: className } = Astro.props;

// Plain names (no prefix) are Lucide icons — prefix them for iconify.
// Normalize PascalCase to kebab-case so legacy icon names keep working.
const resolved = icon.includes(":") ? icon : `lucide:${toLucideKebab(icon)}`;
---

<AstroIcon name={resolved} class={clsx(className, "size-4", "icon")} />

<style>
  :global(:is(p, li, strong, em, a)) .icon {
    display: inline;
    vertical-align: middle;
  }
</style>
