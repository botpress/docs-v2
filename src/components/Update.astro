---
import { slugify } from "@/lib/icon-utils";
import { Badge } from "./ui/badge";

interface Props {
  label: string;
  class?: string;
}

const { label, class: className } = Astro.props;
const id = slugify(label);
---

<section
  id={id}
  class:list={[
    'grid scroll-mt-20 grid-cols-1 gap-0 border-t border-stone-200 pt-10 pb-10 first:border-t-0 first:pt-0 md:grid-cols-[8rem_minmax(0,1fr)] md:gap-10 dark:border-white/10',
    className,
  ]}
>
  <aside class="not-prose md:sticky md:top-24 md:self-start md:pt-2">
    <a href={`#${id}`} class="no-underline">
      <Badge variant="date">{label}</Badge>
    </a>
  </aside>
  <div class="min-w-0 [&>:first-child]:mt-2">
    <slot />
  </div>
</section>
