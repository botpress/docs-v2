---
import Frame from "./Frame.astro";
interface Props {
  url: string;
}
const { url } = Astro.props;
---

<Frame>
  <iframe
    width="600"
    height="335"
    src={url}
    title="YouTube"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  />
</Frame>
