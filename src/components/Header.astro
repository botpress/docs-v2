---
import type { TabInfo } from '../lib/sidebar-types'
import type { NavbarLink } from '../lib/site-config'

interface Props {
  tabs: TabInfo[]
  activeTab: string | null
  siteName?: string | null
  siteLogo?: string | null
  siteLogoDark?: string | null
  navbarLinks?: readonly NavbarLink[]
}

const { tabs, activeTab, siteName, siteLogo, siteLogoDark, navbarLinks = [] } = Astro.props
const hasLogo = !!(siteLogo || siteLogoDark)
const hasTabs = tabs.length > 0
---

<header class="hidden lg:flex h-14 shrink-0 items-center bg-stone-100 px-6 dark:bg-stone-950">
  <a href="/" class="flex shrink-0 items-center">
    <img
      src={siteLogo ?? siteLogoDark ?? undefined}
      alt={siteName || 'Docs'}
      class:list={[
        'h-7 w-auto shrink-0 object-contain',
        siteLogoDark && 'dark:hidden',
      ]}
      style={hasLogo ? undefined : { display: 'none' }}
    />
    <img
      src={siteLogoDark ?? undefined}
      alt={siteName || 'Docs'}
      class:list={[
        'h-7 w-auto shrink-0 object-contain',
        siteLogoDark ? 'hidden dark:block' : 'hidden',
      ]}
    />
    <span
      class="text-sm font-semibold text-stone-900 dark:text-stone-100"
      style={hasLogo ? { display: 'none' } : undefined}
    >{siteName || 'Docs'}</span>
  </a>

  <div class="ml-auto flex items-center gap-3">
    {hasTabs && (
      <nav class="flex items-center gap-x-6">
        {tabs.map((tab) => {
          const isActive = tab.slug === activeTab
          return (
            <a
              href={tab.href}
              class:list={[
                'flex items-center text-sm font-semibold transition-colors',
                isActive
                  ? 'text-stone-900 dark:text-stone-100'
                  : 'text-stone-500 hover:text-stone-700 dark:text-stone-400 dark:hover:text-stone-200',
              ]}
            >
              {tab.label}
            </a>
          )
        })}
      </nav>
    )}
    {navbarLinks.map((link) => {
      const isExternal = link.external ?? link.href.startsWith('http')
      return link.type === 'button' ? (
        <a
          href={link.href}
          {...(isExternal ? { target: '_blank', rel: 'noreferrer' } : {})}
          class="rounded-lg bg-primary px-3.5 py-1.5 text-sm font-medium text-white transition-opacity hover:opacity-90 dark:bg-primary-dark"
        >
          {link.label}
        </a>
      ) : (
        <a
          href={link.href}
          {...(isExternal ? { target: '_blank', rel: 'noreferrer' } : {})}
          class="text-sm text-stone-500 transition-colors hover:text-stone-700 dark:text-stone-400 dark:hover:text-stone-200"
        >
          {link.label}
        </a>
      )
    })}
  </div>
</header>
