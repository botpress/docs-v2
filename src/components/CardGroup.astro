---
interface Props {
  cols?: number;
  class?: string;
}

const { cols = 2, class: className } = Astro.props;
---

<div
  class:list={[
    "not-prose grid gap-4",
    className,
    {
      "sm:grid-cols-1": cols === 1,
      "sm:grid-cols-2": cols === 2,
      "sm:grid-cols-3": cols === 3,
      "sm:grid-cols-4": cols === 4,
    },
  ]}
>
  <slot />
</div>
