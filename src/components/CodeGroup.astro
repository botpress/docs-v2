---
---
<div class="code-group not-prose">
  <slot />
</div>

<script>
  import { COPY_ICON, CHECK_ICON } from '@/scripts/code-icons'

  let groupCounter = 0

  function initCodeGroups() {
    document.querySelectorAll<HTMLElement>('.code-group:not([data-ready])').forEach((group) => {
      const pres = Array.from(group.querySelectorAll<HTMLElement>(':scope > pre.astro-code'))
      if (pres.length === 0) return

      const groupId = groupCounter++

      const tabBar = document.createElement('div')
      tabBar.className = 'code-group-tabs'
      tabBar.setAttribute('role', 'tablist')

      const copyBtn = document.createElement('button')
      copyBtn.className = 'code-group-copy'
      copyBtn.setAttribute('aria-label', 'Copy code')
      copyBtn.innerHTML = COPY_ICON

      let activeIndex = 0

      const tabs: HTMLButtonElement[] = []

      pres.forEach((pre, i) => {
        const title = pre.getAttribute('data-title') || `File ${i + 1}`
        const tabId = `cg-tab-${groupId}-${i}`
        const panelId = `cg-panel-${groupId}-${i}`

        const tab = document.createElement('button')
        tab.className = 'code-group-tab'
        tab.id = tabId
        tab.textContent = title
        tab.setAttribute('role', 'tab')
        tab.setAttribute('aria-selected', i === 0 ? 'true' : 'false')
        tab.setAttribute('aria-controls', panelId)

        pre.id = panelId
        pre.setAttribute('role', 'tabpanel')
        pre.setAttribute('aria-labelledby', tabId)

        if (i === 0) tab.dataset.active = 'true'
        tab.addEventListener('click', () => {
          activeIndex = i
          tabs.forEach((t, j) => {
            t.dataset.active = j === i ? 'true' : 'false'
            t.setAttribute('aria-selected', j === i ? 'true' : 'false')
          })
          pres.forEach((p, j) => {
            p.hidden = j !== i
          })
        })
        tabs.push(tab)
        tabBar.appendChild(tab)
      })

      tabBar.appendChild(copyBtn)

      copyBtn.addEventListener('click', async () => {
        const code = pres[activeIndex]?.querySelector('code')?.textContent ?? ''
        await navigator.clipboard.writeText(code)
        copyBtn.innerHTML = CHECK_ICON
        setTimeout(() => { copyBtn.innerHTML = COPY_ICON }, 2000)
      })

      pres.forEach((pre, i) => {
        if (i > 0) pre.hidden = true
      })

      group.insertBefore(tabBar, group.firstChild)
      group.dataset.ready = 'true'
    })
  }

  document.addEventListener('DOMContentLoaded', initCodeGroups)
  document.addEventListener('astro:page-load', initCodeGroups)
</script>
