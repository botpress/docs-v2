---
import PageOptions from "../components/page-options";
import DocsLayout from "../layouts/DocsLayout.astro";
import { render } from "astro:content";
import { toMarkdownPath } from "../lib/markdown-routes";
import { getSiteContext, getPageContext } from "@/bach";

const DEFAULT_DESCRIPTION =
  "Botpress documentation for building, deploying, and managing AI agents.";

const { defaultEntriesBySlug } = await getSiteContext();

const rootEntry = defaultEntriesBySlug.get("index");

if (!rootEntry) {
  throw new Error(
    `Could not find index page — expected an index.md or index.mdx in the default collection`,
  );
}

const { Content } = await render(rootEntry);

const {
  title,
  description: pageDescription,
  sidebar,
  activeTab,
  sidebarTree,
} = await getPageContext(Astro.url.pathname, rootEntry);

const description = pageDescription ?? DEFAULT_DESCRIPTION;
const useProse = "prose" in rootEntry.data && rootEntry.data.prose !== false;
const markdownUrl = toMarkdownPath(Astro.url.pathname);
---

<DocsLayout
  title={title}
  description={description}
  sidebar={sidebar}
  activeTab={activeTab}
  sidebarTree={sidebarTree}
>
  {
    useProse ? (
      <div
        class="mx-auto flex w-full max-w-5xl gap-10 px-8 py-8 sm:px-8 sm:py-10 lg:px-16"
        data-pagefind-body
      >
        <article class="min-w-0 flex-1">
          <div class="mb-4 flex justify-end">
            <PageOptions client:load markdownUrl={markdownUrl} />
          </div>

          <div class="prose prose-stone mt-6 max-w-none prose-headings:text-stone-900 prose-headings:font-semibold prose-p:text-stone-600 prose-a:text-stone-900 dark:prose-headings:text-stone-100 dark:prose-p:text-stone-300 dark:prose-a:text-stone-100">
            <Content />
          </div>
        </article>
      </div>
    ) : (
      <div data-pagefind-body>
        <Content />
      </div>
    )
  }
</DocsLayout>
