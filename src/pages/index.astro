---
import PageOptions from '../components/page-options'
import DocsLayout from '../layouts/DocsLayout.astro'
import { getCollection, render } from 'astro:content'
import { toMarkdownPath } from '../lib/markdown-routes'
import { computeStrippedSlug } from '../lib/sidebar-tree'
import path from 'node:path'

const contentDir = path.resolve('./src/content/docs')
const entries = await getCollection('docs')

const rootEntry = entries.find((e) => {
  const stripped = computeStrippedSlug(e.id.replace(/\.(md|mdx)$/, ''), contentDir)
  return stripped === 'index'
})

if (!rootEntry) {
  throw new Error('Could not find index page — expected a docs/index.md or docs/index.mdx')
}

const { Content } = await render(rootEntry)
const title = rootEntry.data.title
const useProse = rootEntry.data.prose !== false
const markdownUrl = toMarkdownPath(Astro.url.pathname)
---

<DocsLayout title={title}>
  {useProse ? (
    <div class="mx-auto flex w-full max-w-5xl gap-10 px-8 py-8 sm:px-8 sm:py-10 lg:px-16" data-pagefind-body>
      <article class="min-w-0 flex-1">
        <div class="mb-4 flex justify-end">
          <PageOptions client:load markdownUrl={markdownUrl} />
        </div>

        <div class="prose prose-stone mt-6 max-w-none prose-headings:text-stone-900 prose-headings:font-semibold prose-p:text-stone-600 prose-a:text-stone-900 dark:prose-headings:text-stone-100 dark:prose-p:text-stone-300 dark:prose-a:text-stone-100">
          <Content />
        </div>
      </article>
    </div>
  ) : (
    <div data-pagefind-body>
      <Content />
    </div>
  )}
</DocsLayout>
