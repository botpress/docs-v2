---
import DocsLayout from '../layouts/DocsLayout.astro'
import { getCollection } from 'astro:content'
import { buildSidebarTree } from '../lib/sidebar-tree'
import { siteConfig } from '../lib/site-config'
import path from 'node:path'

const entries = await getCollection('docs')
const contentDir = path.resolve('./src/content/docs')
const tree = buildSidebarTree(entries, contentDir)
---

<DocsLayout title={siteConfig.name}>
  <div class="flex h-full w-full items-start justify-center overflow-y-auto px-4 pt-8" data-hc-landing>
    <div class="flex w-full max-w-[36rem] flex-col items-start py-12">
      <h1 class="text-2xl font-medium text-stone-500 dark:text-stone-400">Welcome</h1>
      <p class="text-2xl font-medium text-stone-900 dark:text-stone-100">How can we help you?</p>

      <div class="mt-8 w-full">
        <button
          type="button"
          class="relative flex h-12 w-full cursor-pointer items-center rounded-2xl border border-stone-200 bg-white pl-11 pr-4 text-sm text-stone-500 shadow-xs transition-[border-color] hover:border-stone-300 dark:border-stone-700 dark:bg-stone-800 dark:text-stone-400 dark:hover:border-stone-600"
          data-hc-landing-search
        >
          <svg class="absolute top-1/2 left-4 size-4 -translate-y-1/2 text-stone-400 dark:text-stone-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
          Search docs...
        </button>
      </div>

      <script>
        document.querySelector('[data-hc-landing-search]')?.addEventListener('click', () => {
          window.dispatchEvent(new CustomEvent('hc:open-search'))
        })
      </script>

      {tree.length > 0 && (
        <div class="mt-12 grid w-full gap-3 sm:grid-cols-2">
          {tree.map((node) => {
            if (node.type === 'category') {
              const firstArticle = node.children.find((c) => c.type === 'article')
              const href = firstArticle?.type === 'article' ? firstArticle.href : '#'
              return (
                <a
                  href={href}
                  class="group rounded-xl border border-stone-200 bg-white p-5 transition-colors hover:border-stone-300 dark:border-stone-800 dark:bg-stone-900 dark:hover:border-stone-700"
                >
                  <h3 class="text-sm font-semibold text-stone-900 transition-colors group-hover:text-stone-700 dark:text-stone-100 dark:group-hover:text-stone-200">
                    {node.label}
                  </h3>
                  <p class="mt-1 text-xs text-stone-500 dark:text-stone-400">
                    {node.children.filter((c) => c.type === 'article').length} articles
                  </p>
                </a>
              )
            }
            return (
              <a
                href={node.href}
                class="group rounded-xl border border-stone-200 bg-white p-5 transition-colors hover:border-stone-300 dark:border-stone-800 dark:bg-stone-900 dark:hover:border-stone-700"
              >
                <h3 class="text-sm font-semibold text-stone-900 transition-colors group-hover:text-stone-700 dark:text-stone-100 dark:group-hover:text-stone-200">
                  {node.title}
                </h3>
              </a>
            )
          })}
        </div>
      )}
    </div>
  </div>
</DocsLayout>
