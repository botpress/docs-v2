---
import PageOptions from "../components/page-options";
import DocsLayout from "../layouts/DocsLayout.astro";
import { render } from "astro:content";
import { toMarkdownPath } from "../lib/markdown-routes";
import {
  DEFAULT_DESCRIPTION,
  readDocsConfig,
  getDefaultCollection,
  fetchCollectionEntries,
} from "@/bach";

const docsConfig = await readDocsConfig();
const defaultCollection = getDefaultCollection(docsConfig);

const entries = await fetchCollectionEntries(defaultCollection);

const rootEntry = entries.find((e) => e.id === "index");

if (!rootEntry) {
  throw new Error(
    `Could not find index page — expected a ${defaultCollection}/index.md or ${defaultCollection}/index.mdx`,
  );
}

const { Content } = await render(rootEntry as never);
const title = rootEntry.data.title as string;
const description =
  (rootEntry.data.description as string | undefined) ?? DEFAULT_DESCRIPTION;
const useProse = rootEntry.data.prose !== false;
const markdownUrl = toMarkdownPath(Astro.url.pathname);
---

<DocsLayout title={title} description={description}>
  {
    useProse ? (
      <div
        class="mx-auto flex w-full max-w-5xl gap-10 px-8 py-8 sm:px-8 sm:py-10 lg:px-16"
        data-pagefind-body
      >
        <article class="min-w-0 flex-1">
          <div class="mb-4 flex justify-end">
            <PageOptions client:load markdownUrl={markdownUrl} />
          </div>

          <div class="prose prose-stone mt-6 max-w-none prose-headings:text-stone-900 prose-headings:font-semibold prose-p:text-stone-600 prose-a:text-stone-900 dark:prose-headings:text-stone-100 dark:prose-p:text-stone-300 dark:prose-a:text-stone-100">
            <Content />
          </div>
        </article>
      </div>
    ) : (
      <div data-pagefind-body>
        <Content />
      </div>
    )
  }
</DocsLayout>
