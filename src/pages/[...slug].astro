---
import PageNavigation from "../components/page-navigation";
import DocsLayout from "../layouts/DocsLayout.astro";
import APIPage from "../components/api-page";
import DocsPage from "../components/docs-page.astro";
import { toMarkdownPath } from "../lib/markdown-routes";
import { getPageContext, generateStaticPaths } from "@/bach";

const DEFAULT_DESCRIPTION =
  "Botpress documentation for building, deploying, and managing AI agents.";

export const getStaticPaths = generateStaticPaths;

const { entry } = Astro.props;
const {
  isApi,
  title,
  description: pageDescription,
  breadcrumbs,
  prev,
  next,
  apiData,
  sidebar,
  activeTab,
  sidebarTree,
} = await getPageContext(Astro.url.pathname, entry);

const description = pageDescription ?? DEFAULT_DESCRIPTION;
const markdownUrl = toMarkdownPath(Astro.url.pathname);
---

<DocsLayout
  title={title}
  description={description}
  breadcrumbs={breadcrumbs}
  sidebar={sidebar}
  activeTab={activeTab}
  sidebarTree={sidebarTree}
>
  {
    isApi ? (
      <div
        class="flex w-full justify-center px-8 pt-10 pb-8 sm:px-8 sm:pt-12 sm:pb-10 lg:px-16"
        data-pagefind-body
      >
        <div
          class="min-w-0 flex-1"
          style="max-width: calc(40rem + 2.5rem + 28rem)"
        >
          <APIPage
            client:load
            endpoint={apiData!.endpoint}
            title={title}
            breadcrumbs={breadcrumbs}
            markdownUrl={markdownUrl}
          />

          <div class="max-w-[40rem] not-prose">
            <PageNavigation prev={prev} next={next} />
          </div>
        </div>
      </div>
    ) : (
      <DocsPage
        entry={entry}
        breadcrumbs={breadcrumbs}
        markdownUrl={markdownUrl}
        prev={prev}
        next={next}
      />
    )
  }
</DocsLayout>
