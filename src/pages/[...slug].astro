---
import PageNavigation from "../components/page-navigation";
import DocsLayout from "../layouts/DocsLayout.astro";
import APIPage from "../components/api-page";
import DocsPage from "../components/docs-page.astro";
import { toMarkdownPath } from "../lib/markdown-routes";
import {
  buildBreadcrumbs,
  getSidebarTree,
  getAdjacentPages,
  getReferencedCollections,
  getDefaultCollection,
  readDocsConfig,
  isApiEntry,
  fetchCollectionEntries,
  normalizeEntryId,
  resolveActiveSidebarTree,
} from "@/bach";
import { DEFAULT_DESCRIPTION } from "@/bach";

const docsConfig = await readDocsConfig();
const { treeResult, titleMap } = await getSidebarTree(docsConfig);

export async function getStaticPaths() {
  const config = await readDocsConfig();
  const names = Array.from(getReferencedCollections(config));
  const _defaultCollection = getDefaultCollection(config);

  const allPaths: Array<{
    params: { slug: string };
    props: {
      entry: {
        id: string;
        collection: string;
        body?: string;
        data: Record<string, unknown>;
        render(): Promise<unknown>;
      };
      collectionName: string;
    };
  }> = [];

  for (const name of names) {
    try {
      const entries = await fetchCollectionEntries(name);
      for (const entry of entries) {
        let slug =
          name === _defaultCollection ? normalizeEntryId(entry.id) : entry.id;
        if (slug === "index") continue;
        allPaths.push({
          params: { slug },
          props: { entry, collectionName: name },
        });
      }
    } catch {
      // Skip missing collections
    }
  }

  return allPaths;
}

const { entry } = Astro.props;
const isApi = isApiEntry(entry);

const title = entry.data.title as string;
const description =
  (entry.data.description as string | undefined) ?? DEFAULT_DESCRIPTION;
const markdownUrl = toMarkdownPath(Astro.url.pathname);

let breadcrumbs: { label: string; href?: string }[];

if (isApi) {
  breadcrumbs = [{ label: entry.data.apiLabel }];
} else {
  breadcrumbs = await buildBreadcrumbs(entry.id, title, titleMap);
}

const currentPath = Astro.url.pathname;
const { sidebarTree } = resolveActiveSidebarTree(treeResult, currentPath);
const { prev, next } = getAdjacentPages(sidebarTree, currentPath);
---

<DocsLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  {
    isApi ? (
      <div
        class="flex w-full justify-center px-8 pt-10 pb-8 sm:px-8 sm:pt-12 sm:pb-10 lg:px-16"
        data-pagefind-body
      >
        <div
          class="min-w-0 flex-1"
          style="max-width: calc(40rem + 2.5rem + 28rem)"
        >
          <APIPage
            client:load
            endpoint={entry.data.endpoint}
            title={title}
            breadcrumbs={breadcrumbs}
            markdownUrl={markdownUrl}
          />

          <div class="max-w-[40rem] not-prose">
            <PageNavigation prev={prev} next={next} />
          </div>
        </div>
      </div>
    ) : (
      <DocsPage
        entry={entry}
        breadcrumbs={breadcrumbs}
        markdownUrl={markdownUrl}
        prev={prev}
        next={next}
      />
    )
  }
</DocsLayout>
