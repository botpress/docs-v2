---
import PageNavigation from "../components/page-navigation";
import DocsLayout from "../layouts/DocsLayout.astro";
import APIPage from "../components/api-page";
import DocsPage from "../components/docs-page.astro";
import { getCollection } from "astro:content";
import { toMarkdownPath } from "../lib/markdown-routes";
import {
  buildBreadcrumbs,
  buildSidebarTree,
  buildApiEntriesMap,
  buildApiSidebarData,
  getActiveTab,
  getAdjacentPages,
} from "@/bach";
import path from "node:path";
import { DEFAULT_DESCRIPTION } from "@/bach";

export async function getStaticPaths() {
  const docsEntries = await getCollection("docs");
  const apiEntries = await getCollection("api");

  const docsPaths = docsEntries
    .map((entry) => {
      const rawSlug = entry.id.replace(/\.(md|mdx)$/, "");
      const slug =
        rawSlug === "index" ? "index" : rawSlug.replace(/\/index$/, "");
      return {
        params: { slug },
        props: { entry },
      };
    })
    .filter((p) => p.params.slug !== "index");

  const apiPaths = apiEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));

  return [...docsPaths, ...apiPaths];
}

const { entry } = Astro.props;
const isApi = entry.collection === "api";

const title = entry.data.title;
const description = entry.data.description ?? DEFAULT_DESCRIPTION;
const markdownUrl = toMarkdownPath(Astro.url.pathname);

const contentDir = path.resolve("./src/content/docs");

const docsEntries = await getCollection("docs");
const apiEntries = await getCollection("api");
const { titleMap, methodMap } = buildApiSidebarData(
  docsEntries,
  apiEntries,
  contentDir,
);
const apiEntriesMap = buildApiEntriesMap(apiEntries);
const treeResult = await buildSidebarTree(
  titleMap,
  contentDir,
  methodMap,
  apiEntriesMap,
);

let breadcrumbs: { label: string; href?: string }[];

if (isApi) {
  const { apiLabel } = entry.data;
  breadcrumbs = [{ label: apiLabel }];
} else {
  breadcrumbs = await buildBreadcrumbs(entry.id, contentDir, title, titleMap);
}

const currentPath = Astro.url.pathname;
const hasTabs = treeResult.tabs.length > 0;
const activeTab = hasTabs
  ? getActiveTab(currentPath, treeResult.slugToTab)
  : null;
const sidebarTree =
  hasTabs && activeTab
    ? (treeResult.trees[activeTab] ?? treeResult.defaultTree)
    : treeResult.defaultTree;
const { prev, next } = getAdjacentPages(sidebarTree, currentPath);
---

<DocsLayout title={title} description={description} breadcrumbs={breadcrumbs}>
  {
    isApi ? (
      <div
        class="flex w-full justify-center px-8 pt-10 pb-8 sm:px-8 sm:pt-12 sm:pb-10 lg:px-16"
        data-pagefind-body
      >
        <div
          class="min-w-0 flex-1"
          style="max-width: calc(40rem + 2.5rem + 28rem)"
        >
          <APIPage
            client:load
            endpoint={entry.data.endpoint}
            title={title}
            breadcrumbs={breadcrumbs}
            markdownUrl={markdownUrl}
          />

          <div class="max-w-[40rem] not-prose">
            <PageNavigation prev={prev} next={next} />
          </div>
        </div>
      </div>
    ) : (
      <DocsPage
        entry={entry}
        breadcrumbs={breadcrumbs}
        markdownUrl={markdownUrl}
        prev={prev}
        next={next}
      />
    )
  }
</DocsLayout>
