---
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/geist";
import "../styles/global.css";
import { withBase } from "@/bach/utils";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta name="description" content={description} />
    <meta property="og:description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var t = localStorage.getItem("hc-theme");
            if (
              t === "dark" ||
              (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)
            ) {
              document.documentElement.classList.add("dark");
            } else {
              document.documentElement.classList.remove("dark");
            }
          } catch (_) {}
        }
        applyTheme();
        document.addEventListener("astro:after-swap", applyTheme);
      })();
    </script>
    <script is:inline>
      (function () {
        function setPanelVars() {
          try {
            var isOpen =
              window.localStorage.getItem("docs-assistant-panel-open") === "1";
            var rawWidth = window.localStorage.getItem(
              "docs-assistant-panel-width",
            );
            var width = rawWidth ? parseFloat(rawWidth) : 30;
            if (isNaN(width)) width = 30;
            if (width > 100) width = 30;
            var MIN = 25,
              MAX = 40;
            if (width < MIN) width = MIN;
            if (width > MAX) width = MAX;
            document.documentElement.style.setProperty(
              "--assistant-panel-width",
              isOpen ? width + "%" : "48px",
            );
            document.documentElement.dataset.assistantPanelOpen = isOpen
              ? "true"
              : "false";
          } catch (_) {
            document.documentElement.style.setProperty(
              "--assistant-panel-width",
              "48px",
            );
            document.documentElement.dataset.assistantPanelOpen = "false";
          }
        }
        setPanelVars();
        document.addEventListener("astro:after-swap", setPanelVars);
      })();
    </script>
  </head>
  <body class="min-h-dvh antialiased">
    <slot />
  </body>
</html>
