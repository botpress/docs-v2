---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/header";
import Sidebar from "../components/sidebar";
import MobileSidebar from "../components/mobile-sidebar";
import SearchOverlay from "../components/search-overlay";
import type { SidebarTreeResult, SidebarNode } from "@/bach/types";
import { siteConfig } from "../lib/site-config";
import { AssistantPanel } from "../components/assistant-panel";
import { MobileAssistant } from "../components/docs-assistant/mobile-assistant";
import { PageStateBridge } from "../components/docs-assistant/page-state-bridge";

interface Props {
  title: string;
  description: string;
  breadcrumbs?: { label: string; href?: string }[];
  sidebar: SidebarTreeResult;
  activeTab: string | null;
  sidebarTree: SidebarNode[];
}

const { title, description, breadcrumbs, sidebar, activeTab, sidebarTree } =
  Astro.props;

const currentPath = Astro.url.pathname;

const navItems: { label: string; href: string; icon?: string }[] = [
  {
    label: "Community Discord",
    href: "https://discord.com/invite/botpress",
    icon: `<svg class="h-4 w-4 bg-current" style="mask-image: url('https://d3gk2c5xim1je2.cloudfront.net/v7.1.0/brands/discord.svg'); mask-repeat: no-repeat; mask-position: center center;"></svg>`,
  },
  {
    label: "News & Resources",
    href: "https://botpress.com/blog",
    icon: "lucide:newspaper",
  },
];
---

<BaseLayout
  title={siteConfig.name ? `${title} – ${siteConfig.name}` : title}
  description={description}
>
  <div class="flex h-dvh flex-col overflow-hidden">
    <Header
      tabs={sidebar.tabs}
      activeTab={activeTab}
      siteName={siteConfig.name}
      siteLogo={siteConfig.logo}
      siteLogoDark={siteConfig.logoDark}
      navbarLinks={siteConfig.navbar.links}
    />

    <MobileSidebar
      client:load
      navItems={navItems}
      tree={sidebarTree}
      currentPath={currentPath}
      siteName={siteConfig.name}
      siteLogo={siteConfig.logo}
      siteLogoDark={siteConfig.logoDark}
      breadcrumbs={breadcrumbs}      
      tabs={sidebar.tabs}
      activeTab={activeTab}
      allTrees={sidebar.tabs.length > 0 ? sidebar.trees : undefined}
    />

    <div class="flex flex-1 overflow-hidden">
      <div class="hidden lg:flex">
        <Sidebar
          client:load
          currentPath={currentPath}
          navItems={navItems}
          tree={sidebarTree}
        />
      </div>

      <main
        class="flex-1 overflow-y-auto rounded-xl border border-stone-200 bg-white ml-2 mr-2 lg:mr-0 mb-2 dark:border-stone-800 dark:bg-stone-900"
      >
        <slot />
      </main>

      <div class="ai-panel-container">
        <AssistantPanel client:only="react" transition:persist />
      </div>
    </div>

    <PageStateBridge
      client:load
      transition:persist
      path={currentPath}
      title={title}
    />

    <MobileAssistant client:only="react" transition:persist />
    <SearchOverlay client:load />
  </div>
</BaseLayout>

<script>
  import "@/scripts/code-copy";
  import "@/scripts/step-anchors";
</script>
