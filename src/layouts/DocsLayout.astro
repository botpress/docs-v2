---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/header";
import Sidebar from "../components/sidebar";
import MobileSidebar from "../components/mobile-sidebar";
import SearchOverlay from "../components/search-overlay";
import {
  getSidebarTree,
  readDocsConfig,
  resolveActiveSidebarTree,
} from "@/bach";
import { siteConfig } from "../lib/site-config";
interface Props {
  title: string;
  description: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, description, breadcrumbs } = Astro.props;

const docsConfig = await readDocsConfig();
const { treeResult } = await getSidebarTree(docsConfig);

const currentPath = Astro.url.pathname;
const { activeTab, sidebarTree } = resolveActiveSidebarTree(
  treeResult,
  currentPath,
);

const navItems: { label: string; href: string; icon?: string }[] = [
  {
    label: "Community Discord",
    href: "https://discord.com/invite/botpress",
    icon: `<svg class="h-4 w-4 bg-current" style="mask-image: url('https://d3gk2c5xim1je2.cloudfront.net/v7.1.0/brands/discord.svg'); mask-repeat: no-repeat; mask-position: center center;"></svg>`,
  },
  {
    label: "News & Resources",
    href: "https://botpress.com/blog",
    icon: "lucide:newspaper",
  },
];
---

<BaseLayout
  title={siteConfig.name ? `${title} – ${siteConfig.name}` : title}
  description={description}
>
  <div class="flex h-dvh flex-col overflow-hidden">
    <Header
      tabs={treeResult.tabs}
      activeTab={activeTab}
      siteName={siteConfig.name}
      siteLogo={siteConfig.logo}
      siteLogoDark={siteConfig.logoDark}
      navbarLinks={siteConfig.navbar.links}
    />

    <MobileSidebar
      client:load
      navItems={navItems}
      tree={sidebarTree}
      currentPath={currentPath}
      siteName={siteConfig.name}
      siteLogo={siteConfig.logo}
      siteLogoDark={siteConfig.logoDark}
      breadcrumbs={breadcrumbs}
      tabs={treeResult.tabs}
      activeTab={activeTab}
      allTrees={treeResult.tabs.length > 0 ? treeResult.trees : undefined}
    />

    <div class="flex flex-1 overflow-hidden">
      <div class="hidden lg:flex">
        <Sidebar
          client:load
          currentPath={currentPath}
          navItems={navItems}
          tree={sidebarTree}
        />
      </div>

      <main
        class="flex-1 overflow-y-auto rounded-xl border border-stone-200 bg-white mx-[calc(var(--spacing)*2)] mb-[calc(var(--spacing)*2)] dark:border-stone-800 dark:bg-stone-900"
      >
        <slot />
      </main>
    </div>

    <SearchOverlay client:load />
  </div>
</BaseLayout>
