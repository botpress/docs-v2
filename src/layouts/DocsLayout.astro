---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/header";
import Sidebar from "../components/sidebar";
import MobileSidebar from "../components/mobile-sidebar";
import SearchOverlay from "../components/search-overlay";
import { getCollection } from "astro:content";
import {
  buildSidebarTree,
  normalizeCollectionEntries,
  getActiveTab,
} from "../lib/sidebar-tree";
import { siteConfig } from "../lib/site-config";
import path from "node:path";
interface Props {
  title: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, breadcrumbs } = Astro.props;

const entries = await getCollection("docs");
const contentDir = path.resolve("./src/content/docs");

const articles = normalizeCollectionEntries(entries, contentDir);

const titleMap = new Map<string, string>();
const methodMap = new Map<string, string>();
for (const a of articles) {
  titleMap.set(a.slug, a.title);
  if (a.method) methodMap.set(a.slug, a.method);
}

const result = buildSidebarTree(titleMap, contentDir, methodMap);

const currentPath = Astro.url.pathname;
const hasTabs = result.tabs.length > 0;
const activeTab = hasTabs ? getActiveTab(currentPath, result.slugToTab) : null;
const sidebarTree =
  hasTabs && activeTab
    ? (result.trees[activeTab] ?? result.defaultTree)
    : result.defaultTree;

const navItems: { label: string; href: string; icon?: string }[] = [
  {
    label: "Community Discord",
    href: "https://discord.com/invite/botpress",
    icon: `<svg class="h-4 w-4 bg-current" style="mask-image: url('https://d3gk2c5xim1je2.cloudfront.net/v7.1.0/brands/discord.svg'); mask-repeat: no-repeat; mask-position: center center;"></svg>`,
  },
  {
    label: "News & Resources",
    href: "https://botpress.com/blog",
    icon: "lucide:newspaper",
  },
];
---

<BaseLayout title={siteConfig.name ? `${title} – ${siteConfig.name}` : title}>
  <div class="flex h-dvh flex-col overflow-hidden">
    <Header
      tabs={result.tabs}
      activeTab={activeTab}
      siteName={siteConfig.name}
      siteLogo={siteConfig.logo}
      siteLogoDark={siteConfig.logoDark}
      navbarLinks={siteConfig.navbar.links}
    />

    <MobileSidebar
      client:load
      navItems={navItems}
      tree={sidebarTree}
      currentPath={currentPath}
      siteName={siteConfig.name}
      siteLogo={siteConfig.logo}
      siteLogoDark={siteConfig.logoDark}
      breadcrumbs={breadcrumbs}
      tabs={result.tabs}
      activeTab={activeTab}
      allTrees={hasTabs ? result.trees : undefined}
    />

    <div class="flex flex-1 overflow-hidden">
      <div class="hidden lg:flex">
        <Sidebar
          client:load
          currentPath={currentPath}
          navItems={navItems}
          tree={sidebarTree}
        />
      </div>

      <main
        class="flex-1 overflow-y-auto rounded-xl border border-stone-200 bg-white mx-[calc(var(--spacing)*2)] mb-[calc(var(--spacing)*2)] dark:border-stone-800 dark:bg-stone-900"
      >
        <slot />
      </main>
    </div>

    <SearchOverlay client:load />
  </div>
</BaseLayout>
