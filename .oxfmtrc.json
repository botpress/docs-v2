{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": true,
  "printWidth": 120,
  "tabWidth": 2,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "sortPackageJson": false,
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    ".vite",
    ".astro",
    "*.local",
    ".DS_Store",
    "*.log",
    "*.tsbuildinfo",
    ".env",
    ".env.local",
    "coverage"
  ]
}
